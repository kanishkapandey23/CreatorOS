# CreatorOS Backend - Environment Variables Template
# ================================================
# Copy this to .env in the backend/ directory and fill in your values
# DO NOT commit .env to version control

# ==================== LLM Configuration ====================
# Modes: gemini | groq | local
# gemini is highly recommended and configured by default.
LLM_MODE=gemini

# --- Cloud APIs (fast, free tiers — best for demos on CPU) ---
# Gemini (recommended): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq (alternative, also very fast): https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Local models (slow on CPU; use only with GPU or offline dev) ---
LLM_MODEL_FAMILY=qwen
LLM_MODEL_SIZE=medium
# LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# ==================== Database Configuration ====================
# Default: SQLite (ideal for development)
DATABASE_URL=sqlite:///./creatoros.db

# For PostgreSQL (uncomment and fill in):
# DATABASE_URL=postgresql://user:password@localhost:5432/creatoros

# For MySQL (uncomment and fill in):
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/creatoros

# ==================== Security Configuration ====================
# JWT secret key (use a strong random string in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== CORS Configuration ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend URL (OAuth redirect target after successful login)
FRONTEND_URL=http://localhost:3000

# Backend public URL (used for OAuth redirect URIs)
API_BASE_URL=http://127.0.0.1:8000

# ==================== OAuth Configuration ====================
# Google — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://127.0.0.1:8000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub — https://github.com/settings/developers
# Authorization callback URL: http://127.0.0.1:8000/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ==================== Logging Configuration ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== HuggingFace Configuration ====================
# Required for gated Llama models — get from https://huggingface.co/settings/tokens
# Alias: HUGGING_FACE_HUB_TOKEN
# HF_TOKEN=hf_your_token_here

# ==================== API Configuration ====================
API_HOST=0.0.0.0
API_PORT=8000

# ==================== Development Settings ====================
DEBUG=False
RELOAD=True
